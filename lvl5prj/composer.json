{
    "name": "mioky/lvl5prj",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Mioky\\Lvl5prj\\": "src/"
        }
    },
    "require": {
        "mioky/lvl5": "dev-main"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "snif": "vendor/bin/phpstan analyse --level=8",
        "phpstan": "./vendor/bin/phpcbf --standard=PSR12"
    }
}
